<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="io.github.nzilberberg.tomeroam"
    android:versionCode="14"
    android:versionName="2026-07-12.18">

  <uses-permission android:name="android.permission.INTERNET"/>
  <!-- Track B self-update: hand the downloaded APK to the system installer. -->
  <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

  <uses-sdk android:minSdkVersion="24" android:targetSdkVersion="35"/>

  <application
      android:label="TomeRoam"
      android:icon="@mipmap/ic_launcher"
      android:theme="@style/AppTheme"
      android:networkSecurityConfig="@xml/network_security_config"
      android:allowBackup="true">
    <activity
        android:name=".MainActivity"
        android:exported="true"
        android:screenOrientation="portrait"
        android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize"
        android:launchMode="singleTask">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>

    <!-- Exposes ONLY the downloaded update APK to the system installer (custom,
         framework-only — this dependency-free build has no AndroidX FileProvider). -->
    <provider
        android:name=".ApkFileProvider"
        android:authorities="io.github.nzilberberg.tomeroam.fileprovider"
        android:exported="false"
        android:grantUriPermissions="true"/>
  </application>
</manifest>
