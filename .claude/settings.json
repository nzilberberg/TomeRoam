{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "shell": "bash",
            "command": "NODE=\"$(git config --get tomeroam.node)\"; [ -z \"$NODE\" ] && NODE=node; \"$NODE\" tools/hooks/claude-precommit.mjs",
            "timeout": 180,
            "statusMessage": "tomeroam pre-commit checks"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "NODE=\"$(git config --get tomeroam.node)\"; [ -z \"$NODE\" ] && NODE=node; \"$NODE\" tools/hooks/ci-watch.mjs",
            "asyncRewake": true,
            "timeout": 1600,
            "statusMessage": "watching CI",
            "rewakeSummary": "CI result",
            "rewakeMessage": "CI verification after your push:"
          }
        ]
      }
    ]
  }
}
